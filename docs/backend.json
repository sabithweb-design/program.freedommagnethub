
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information including role, status, and cohort start date for Freedom Magnet Hub.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "status": { "type": "boolean", "description": "Active or deactivated status" },
        "cohortStartDate": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["uid", "email", "role", "cohortStartDate"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Educational lesson content for the 90-day program in Freedom Magnet Hub.",
      "type": "object",
      "properties": {
        "courseId": { "type": "string", "description": "Reference to the parent Course ID" },
        "dayNumber": { "type": "number" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "youtubeVideoId": { "type": "string" },
        "thumbnailUrl": { "type": "string", "description": "URL for the lesson preview image" },
        "isLocked": { "type": "boolean", "default": false },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["dayNumber", "youtubeVideoId", "courseId"]
    },
    "Course": {
      "title": "Course",
      "description": "A course available in the hub with stylized progress tracking.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "videos": { "type": "string", "description": "e.g., '4/6'" },
        "progress": { "type": "number", "description": "Percentage value (0-100)" },
        "imageUrl": { "type": "string" },
        "isLatestLearned": { "type": "boolean" },
        "userId": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "isLocked": { "type": "boolean", "default": false },
        "rating": { "type": "number", "description": "Star rating (0-5)" },
        "reviewCount": { "type": "number", "description": "Total number of reviews" }
      },
      "required": ["title", "author", "category", "videos", "progress", "imageUrl"]
    },
    "UserLessonProgress": {
      "title": "User Lesson Progress",
      "description": "Tracks if a user has completed a specific lesson.",
      "type": "object",
      "properties": {
        "completedAt": { "type": "object", "description": "Firestore Timestamp" }
      }
    }
  },
  "auth": {
    "providers": ["password", "emailLink"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles indexed by UID."
    },
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Lessons in the training program curriculum."
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Educational courses with progress and metadata."
    },
    "/users/{userId}/completedLessons/{lessonId}": {
      "schema": "UserLessonProgress",
      "description": "Subcollection to track completed lessons per user."
    }
  }
}
