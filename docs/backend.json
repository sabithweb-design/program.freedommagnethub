
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information including role (main_admin, sub_admin, student), status, and cohort start date.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "status": { "type": "boolean", "description": "Active or deactivated status" },
        "cohortStartDate": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["uid", "email", "role", "cohortStartDate"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Educational lesson content for the training programs.",
      "type": "object",
      "properties": {
        "courseId": { "type": "string", "description": "Reference to the parent Course ID" },
        "dayNumber": { "type": "number" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "actionPlan": { "type": "string", "description": "Specific action steps for the student" },
        "youtubeVideoId": { "type": "string" },
        "thumbnailUrl": { "type": "string", "description": "URL for the lesson preview image" },
        "pdfUrl": { "type": "string", "description": "URL for downloadable PDF resources" },
        "isLocked": { "type": "boolean", "default": false },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["dayNumber", "youtubeVideoId", "courseId"]
    },
    "Course": {
      "title": "Course",
      "description": "A program folder with scoped access for Sub Admins and enrolled Students.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "videos": { "type": "string" },
        "progress": { "type": "number" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "isLocked": { "type": "boolean", "default": false },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "adminIds": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of Sub Admin UIDs who can manage this program."
        },
        "studentIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of Student UIDs enrolled in this program."
        }
      },
      "required": ["title", "category"]
    },
    "UserLessonProgress": {
      "title": "User Lesson Progress",
      "description": "Tracks if a user has completed a specific lesson.",
      "type": "object",
      "properties": {
        "completedAt": { "type": "object", "description": "Firestore Timestamp" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles indexed by UID."
    },
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Lessons in the training program curriculum."
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Educational courses with progress and metadata."
    },
    "/users/{userId}/completedLessons/{lessonId}": {
      "schema": "UserLessonProgress",
      "description": "Subcollection to track completed lessons per user."
    }
  }
}
