{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information including role and cohort start date.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "cohortStartDate": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["uid", "email", "role", "cohortStartDate"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Educational lesson content for the 90-day program.",
      "type": "object",
      "properties": {
        "dayNumber": { "type": "number" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "youtubeVideoId": { "type": "string" },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["dayNumber", "title", "description", "youtubeVideoId"]
    },
    "Course": {
      "title": "Course",
      "description": "A course available in the hub with stylized progress tracking.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "videos": { "type": "string", "description": "e.g., '4/6'" },
        "progress": { "type": "number", "description": "Percentage value (0-100)" },
        "imageUrl": { "type": "string" },
        "isLatestLearned": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["title", "author", "category", "videos", "progress", "imageUrl"]
    }
  },
  "auth": {
    "providers": ["password", "emailLink"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles indexed by UID."
    },
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Lessons in the training program."
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Educational courses with progress and metadata."
    }
  }
}