
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Super Admin check: Global admin email and role
    function isSuperAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admin@freedommagnethub.com';
    }

    // Scoped Admin check: Has admin role AND is explicitly assigned to the course
    function isCourseAdmin(courseId) {
      return request.auth != null && (
        isSuperAdmin() || 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' && 
         request.auth.uid in get(/databases/$(database)/documents/courses/$(courseId)).data.adminIds)
      );
    }

    // Is any Admin (Super or Scoped)
    function isAdmin() {
       return request.auth != null && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profile: Users see their own. Admins see profiles to manage them.
    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Explicitly allow Super Admin to list all. Scoped admins only get.
      allow list: if isSuperAdmin();
      // Allow creation of students by any admin.
      allow create: if isAdmin() && request.resource.data.role == 'student';
      // Super admin can create anything (like other admins).
      allow create: if isSuperAdmin();
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      
      match /completedLessons/{lessonId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Lessons: Scoped admins can manage lessons belonging to their assigned courses.
    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write, create, delete: if request.auth != null && (
        isSuperAdmin() || 
        isCourseAdmin(request.resource.data.courseId) || 
        isCourseAdmin(resource.data.courseId)
      );
    }

    // Courses: Super Admin manages all. Scoped Admin manages assigned courses. 
    // Students can read if enrolled.
    match /courses/{courseId} {
      allow read: if request.auth != null && (
        isSuperAdmin() || 
        isCourseAdmin(courseId) || 
        request.auth.uid in resource.data.studentIds
      );
      allow create: if isAdmin();
      allow update, delete: if isCourseAdmin(courseId);
    }
  }
}
