
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Super Admin: Has full control over everything.
    function isSuperAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admin@freedommagnethub.com';
    }

    // Sub Admin: Can manage a course if their UID is in the course.adminIds array.
    function isSubAdminForCourse(courseId) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null && 
             user.role == 'admin' && 
             request.auth.uid in get(/databases/$(database)/documents/courses/$(courseId)).data.adminIds;
    }

    // Is any type of Admin (Main or Sub)
    function isAdmin() {
       return request.auth != null && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profile: Users see their own. Super Admin sees all. 
    // Sub admins can read (get) a profile to verify a student's existence for enrollment.
    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow list: if isSuperAdmin();
      allow create: if isAdmin(); // Admins can register new students/admins.
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      
      match /completedLessons/{lessonId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Lessons: Managed by Super Admin or the assigned Sub Admin.
    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write, create, delete: if request.auth != null && (
        isSuperAdmin() || 
        isSubAdminForCourse(request.resource.data.courseId) || 
        (resource != null && isSubAdminForCourse(resource.data.courseId))
      );
    }

    // Courses: 
    // Super Admin manages all. 
    // Sub Admin manages assigned courses. 
    // Students can read if their UID is in the studentIds array.
    match /courses/{courseId} {
      allow read: if request.auth != null && (
        isSuperAdmin() || 
        isSubAdminForCourse(courseId) || 
        request.auth.uid in resource.data.studentIds
      );
      allow create: if isAdmin();
      allow update: if isSuperAdmin() || isSubAdminForCourse(courseId);
      allow delete: if isSuperAdmin();
    }
  }
}
