
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if a user is the absolute platform owner
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@freedommagnethub.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admin@freedommagnethub.com'
      );
    }

    // Any user with an 'admin' role (Main or Sub)
    function isAdmin() {
       return request.auth != null && (
         isSuperAdmin() ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
       );
    }

    // User profiles: Users see their own. Admins can manage all.
    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow list: if request.auth != null && isAdmin(); 
      allow create: if request.auth != null; 
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      
      match /completedLessons/{lessonId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Lessons: Managed by Admins (Main and Sub)
    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write, create, delete: if isAdmin();
    }

    // Courses: 
    match /courses/{courseId} {
      allow read: if request.auth != null && (
        isSuperAdmin() || 
        (resource != null && request.auth.uid in resource.data.adminIds) || 
        (resource != null && request.auth.uid in resource.data.studentIds)
      );
      allow create: if isAdmin();
      allow update: if isSuperAdmin() || (resource != null && request.auth.uid in resource.data.adminIds);
      // Main Admin (SuperAdmin) or an assigned Sub-Admin can delete
      allow delete: if request.auth != null && (isSuperAdmin() || (resource != null && request.auth.uid in resource.data.adminIds));
    }
  }
}
