
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile: Users can only read/write their own profiles.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Lessons: All authenticated users can read all lessons.
    match /lessons/{lessonId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow read: if request.auth != null;
    }

    // Courses: Authenticated users can read all courses. 
    // Write/Create still limited to owners or admins if applicable.
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
    }
  }
}
