rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile: Users can only read/write their own profiles.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Lessons: Secure drip logic
    match /lessons/{lessonId} {
      // Admins can do everything
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Students can only read lessons if they are within their drip timeline
      allow read: if request.auth != null && (
        let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        let cohortStart = userData.cohortStartDate.toMillis();
        let currentTime = request.time.toMillis();
        let diffMillis = currentTime - cohortStart;
        let currentDay = Math.floor(diffMillis / (1000 * 60 * 60 * 24)) + 1;
        
        // Block if lesson dayNumber is in the future
        resource.data.dayNumber <= currentDay
      );
    }
  }
}